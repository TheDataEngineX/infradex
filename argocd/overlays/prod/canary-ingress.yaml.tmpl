apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: dex-app-canary
  namespace: dex
  annotations:
    nginx.ingress.kubernetes.io/canary: "true"
    nginx.ingress.kubernetes.io/canary-weight: "__WEIGHT__"
spec:
  rules:
    - host: api.thedataenginex.org
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: dex-app
                port:
                  number: 17000
