# InfraDEX Environment Variables
# Copy to .env and fill in values — never commit .env

# Terraform — Hetzner VPS
TF_VAR_hetzner_token=

# Terraform — Cloudflare DNS
TF_VAR_cloudflare_api_token=
TF_VAR_cloudflare_zone_id=
TF_VAR_domain=thedataenginex.org

# Kubernetes
KUBECONFIG=~/.kube/config

# ArgoCD
ARGOCD_SERVER=argocd.thedataenginex.org
ARGOCD_AUTH_TOKEN=

# Container registry
REGISTRY_URL=ghcr.io/thedataenginex
REGISTRY_USER=
REGISTRY_PASSWORD=

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
ALERTMANAGER_SLACK_WEBHOOK=

# Secrets (rotate via infradex rotate-secrets)
POSTGRES_PASSWORD=
REDIS_PASSWORD=
MINIO_ROOT_PASSWORD=
